--- a/vllm/model_executor/layers/quantization/compressed_tensors/schemes/compressed_tensors_w8a8_fp8.py
+++ b/vllm/model_executor/layers/quantization/compressed_tensors/schemes/compressed_tensors_w8a8_fp8.py
@@ -163,6 +163,18 @@ class CompressedTensorsW8A8Fp8(CompressedTensorsScheme):

         elif self.strategy == QuantizationStrategy.BLOCK:
             assert self.is_static_input_scheme is False
+            # PATCH (paul/dsv4) skip-marlin-for-bmm: DSV4 wo_a/wo_b on SM12 use
+            # a Triton fp8_einsum kernel that reads the FP8 weight in its
+            # original (N, K) layout. Marlin's process_weights_after_loading
+            # repacks to a tile layout that the einsum can't decode (shape[0]
+            # ends up 256 instead of 4096 at TP=2, failing the divisibility
+            # check). Detect bmm layers via the `is_bmm` attribute set in
+            # DSV4 attention init and skip the Marlin repack.
+            if getattr(layer, "is_bmm", False):
+                if not hasattr(layer, "weight_scale") and hasattr(layer, "weight_scale_inv"):
+                    layer.weight_scale = layer.weight_scale_inv
+                layer.input_scale = None
+                return
             self.fp8_linear.process_weights_after_loading(layer)

             layer.input_scale = None
