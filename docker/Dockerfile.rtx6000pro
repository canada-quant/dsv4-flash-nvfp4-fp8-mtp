# syntax=docker/dockerfile:1.7
# canada-quant DSv4 NVFP4/W4A16 + MTP on RTX PRO 6000 Blackwell Server Edition (SM 12.0)
#
# Image bakes the v3 recipe (scripts/install_rtx6000pro_v3.sh) verified 2026-05-27.
# Mainline vllm-project/vllm@main is currently blocked at first forward on SM 12.0
# by DeepGEMM Hopper-only kernels (`fp8_einsum`, `tf32_hc_prenorm_gemm`).
# jasl/vllm@27fd665b carries `sm12x_deep_gemm_fallbacks.py` + sibling shim files
# that route to Triton fallbacks on SM 12.0 until upstream PRs land.
#
# Build (on a host with NVIDIA Container Toolkit + ≥30 GB free disk):
#
#   docker build \
#     --build-arg TORCH_CUDA_ARCH_LIST=12.0a \
#     -f docker/Dockerfile.rtx6000pro \
#     -t canada-quant/dsv4-rtx6000pro:v3 \
#     .
#
# Run (mount HF cache so the 172 GB Card B doesn't have to re-download):
#
#   docker run --gpus all --rm -it \
#     --shm-size=16g --ipc=host \
#     -p 8000:8000 \
#     -v $HOME/.cache/huggingface:/root/.cache/huggingface \
#     -e HF_TOKEN=$HF_TOKEN \
#     canada-quant/dsv4-rtx6000pro:v3 \
#     vllm serve canada-quant/DeepSeek-V4-Flash-NVFP4-FP8-MTP \
#       --tensor-parallel-size 4 \
#       --kv-cache-dtype fp8 --block-size 256 \
#       --max-model-len 32768 \
#       --max-num-seqs 8 --max-num-batched-tokens 8192 \
#       --gpu-memory-utilization 0.95 \
#       --speculative-config '{"method":"mtp","num_speculative_tokens":1}' \
#       --tokenizer-mode deepseek_v4 \
#       --reasoning-parser deepseek_v4 \
#       --tool-call-parser deepseek_v4 --enable-auto-tool-choice \
#       --disable-custom-all-reduce \
#       --trust-remote-code \
#       --host 0.0.0.0 --port 8000
#
# NGC PyTorch 26.04 ships PyTorch 2.12.0a0 + Python 3.12.3 + CUDA toolkit.
# jasl/vllm@27fd665b's csrc/libtorch_stable code references the
# `torch/headeronly/util/Float8_e4m3fnuz.h` header which is only present in
# PyTorch 2.7+ stable. NGC 25.04 ships 2.7.0a0 (pre-release) and lacks the
# `torch/headeronly/` namespace, so we need a newer base. 26.04 verified
# 2026-05-27.

ARG BASE_IMAGE=nvcr.io/nvidia/pytorch:26.04-py3
FROM ${BASE_IMAGE}

ARG VLLM_REPO=https://github.com/jasl/vllm.git
ARG VLLM_BRANCH=ds4-sm120-preview-dev
ARG VLLM_PIN=27fd665bdc3ba58afc5c34cbb9034c9fc1a95029
ARG TORCH_CUDA_ARCH_LIST=12.0a
ARG MAX_JOBS=12

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    VLLM_TEST_FORCE_FP8_MARLIN=1 \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    HF_XET_HIGH_PERFORMANCE=1 \
    TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST} \
    MAX_JOBS=${MAX_JOBS} \
    CMAKE_BUILD_PARALLEL_LEVEL=${MAX_JOBS} \
    VLLM_USE_PRECOMPILED=0

# System deps. NGC PyTorch already has CUDA + nvcc + most tooling.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates \
        build-essential ninja-build pkg-config \
        libnuma-dev libnccl-dev libnccl2 \
    && rm -rf /var/lib/apt/lists/*

# Modern cmake (system on jammy is 3.22; vLLM needs ≥3.26) plus vLLM build deps
# that NGC PyTorch doesn't pre-install. NGC pins `packaging==23.2` via a global
# pip constraint at /etc/pip/constraint.txt — `PIP_CONSTRAINT=` overrides it so
# setuptools 77+ can pull `packaging>=24.2` (needed for `packaging.licenses`).
RUN PIP_CONSTRAINT= pip install --upgrade \
        pip "packaging>=24.2" setuptools wheel \
        setuptools_scm setuptools_rust \
    && PIP_CONSTRAINT= pip install --upgrade "cmake>=3.30" ninja

# Clone jasl/vllm at the SM 12.0 verified pin.
WORKDIR /opt
RUN git clone --branch ${VLLM_BRANCH} ${VLLM_REPO} vllm-jasl \
    && cd vllm-jasl \
    && git checkout ${VLLM_PIN} \
    && echo "jasl/vllm pinned at $(git rev-parse --short HEAD)"

WORKDIR /opt/vllm-jasl

# Patch 1 — PR #43722 (MarlinFP8.can_implement block-FP8 refuse)
RUN python3 - <<'PYEOF'
F = "vllm/model_executor/kernels/linear/scaled_mm/marlin.py"
src = open(F).read()
marker = '    @classmethod\n    def can_implement(cls, c: FP8ScaledMMLinearLayerConfig) -> tuple[bool, str | None]:\n        return True, None'
new = """    @classmethod
    def can_implement(cls, c: FP8ScaledMMLinearLayerConfig) -> tuple[bool, str | None]:
        # canada-quant 2026-05-26: MarlinFP8 cannot serve block-FP8 layers; let
        # dispatcher fall through to TritonFp8BlockScaledMMKernel. PR #43722.
        try:
            if c.activation_quant_key.scale.group_shape.is_per_group():
                return False, "MarlinFP8 cannot serve block-FP8 layers"
        except Exception:
            pass
        return True, None"""
if marker in src and "MarlinFP8 cannot serve block-FP8" not in src:
    open(F, "w").write(src.replace(marker, new, 1))
    print("[patch] PR #43722 applied")
else:
    print("[patch] PR #43722 already applied or marker not found")
PYEOF

# Patch 2 — PR #43723 (DSv4 wo_a scale getattr fallback)
# Path is `vllm/models/deepseek_v4/attention.py` at jasl@27fd665b (not under
# `nvidia/ops/` — v3 install script had the wrong path).
RUN python3 - <<'PYEOF'
F = "vllm/models/deepseek_v4/attention.py"
src = open(F).read()
marker = "        wo_a_fp8 = self.wo_a.weight\n        wo_a_scale = self.wo_a.weight_scale_inv"
new = """        wo_a_fp8 = self.wo_a.weight
        # canada-quant 2026-05-26: non-Marlin kernels (Triton block-FP8, Cutlass,
        # DeepGemm) leave the on-disk name `weight_scale`. PR #43723.
        wo_a_scale = getattr(self.wo_a, "weight_scale_inv", None)
        if wo_a_scale is None:
            wo_a_scale = self.wo_a.weight_scale"""
if marker in src:
    open(F, "w").write(src.replace(marker, new, 1))
    print("[patch] PR #43723 applied")
else:
    print("[patch] PR #43723 marker not found (already applied?)")
PYEOF

# Patch 3 — PR #41834 tuned Triton block-FP8 autotune configs for sm_120
RUN git fetch https://github.com/vllm-project/vllm.git refs/pull/41834/head:pr-41834 || true \
    && (git checkout pr-41834 -- \
            vllm/model_executor/layers/quantization/utils/configs/ \
            vllm/model_executor/layers/fused_moe/configs/ 2>/dev/null \
        || echo "[patch] PR #41834 configs already present (skipping)") \
    && echo "[patch] PR #41834 tuned configs applied"

# Patch 4 — Marlin MoE workspace 4× oversize (defensive vs cudaErrorIllegalAddress
# under concurrent W4A16 decode; harmless for NVFP4-only Card B serve).
RUN sed -i 's/sms \* max_blocks_per_sm, dtype=torch.int/sms * max_blocks_per_sm * 4, dtype=torch.int/' \
        vllm/model_executor/layers/quantization/utils/marlin_utils.py \
    && echo "[patch] workspace 4× applied"

# Patch 4b — NGC PyTorch 26.04 ships torch `2.12.0a0+0291f960b6.nv26.04` which
# version-compares >= 2.12.0.dev, so jasl's `is_torch_equal_or_newer("2.12.0.dev")`
# returns True and tries to pass `tuple_return=True` to `torch.fx.passes
# .split_module.split_module()`. NGC's torch fork doesn't have that kwarg yet
# (only PyPI torch 2.12.0 stable does). Force the legacy code path.
RUN python3 - <<'PYEOF'
F = "vllm/compilation/backends.py"
src = open(F).read()
old = '        has_tuple_return = is_torch_equal_or_newer("2.12.0.dev")'
new = '        has_tuple_return = False  # canada-quant: NGC torch fork lacks tuple_return kwarg'
if old in src:
    open(F, "w").write(src.replace(old, new, 1))
    print("[patch] tuple_return=False forced")
else:
    print("[patch] tuple_return marker not found")
    import sys; sys.exit(1)
PYEOF

# Patch 4c — BF16 MTP wo_a fix (upstream issue #43304, root cause for Card B
# blocking at `wo_a.weight_scale` AttributeError). Cherry-pick two commits from
# `canada-quant/vllm:fix/dsv4-mtp-draft-quant-detect`:
#   - 5a49d88: detect BF16 MTP on disk, skip applying main quant_config to MTP
#              block during DeepSeekV4MultiTokenPredictorLayer construction
#   - 5acabf3: BF16 reference path in attention when wo_a is unquantized
#              (mirrors the ROCm branch's existing handling)
# Card B has BF16 MTP by design (recipe choice — don't quantize spec-decode
# heads on MoE). Without this fix, vLLM allocates main-scheme quant slots on
# MTP layers that have no scales on disk -> AttributeError at forward.
RUN git config user.email build@canada-quant.local \
    && git config user.name "build" \
    && git add -A \
    && git commit --allow-empty -m "canada-quant Docker: prior in-place patches" \
    && git remote add canada-quant https://github.com/canada-quant/vllm.git 2>/dev/null || true \
    && git fetch canada-quant fix/dsv4-mtp-draft-quant-detect \
    && (git cherry-pick 5a49d8803 5acabf315 \
        || (echo "[patch] cherry-pick conflict — reset attention.py and retry" \
            && git cherry-pick --abort \
            && git checkout HEAD~1 -- vllm/models/deepseek_v4/attention.py \
            && git commit --allow-empty -m "reset attention.py for clean cherry-pick" \
            && git cherry-pick 5a49d8803 5acabf315)) \
    && echo "[patch] BF16 MTP detect + wo_a BF16 ref path applied"

# Patch 5 — PR #40923 (Marlin MoE sm_120a;sm_121a native cubins). At jasl@27fd665b
# `MARLIN_MOE_ARCHS` is still `"8.0+PTX"` — silent JIT-PTX corruption on SM 12.0.
# The v3 script's grep guard for `12.0a;12.1a` accidentally matches OTHER kernel
# arch lists in CMakeLists.txt and falsely skipped this patch. Apply directly.
RUN if grep -q 'cuda_archs_loose_intersection(MARLIN_MOE_ARCHS "8.0+PTX"' CMakeLists.txt; then \
        sed -i 's|cuda_archs_loose_intersection(MARLIN_MOE_ARCHS "8.0+PTX"|cuda_archs_loose_intersection(MARLIN_MOE_ARCHS "8.0+PTX;9.0a;10.0a;10.1a;10.3a;12.0a;12.1a"|' CMakeLists.txt; \
        echo "[patch] PR #40923 MARLIN_MOE_ARCHS extended"; \
    else \
        echo "[patch] PR #40923 MARLIN_MOE_ARCHS already extended or marker moved"; \
    fi

# vLLM kernel compile (~30-45 min on 12 vCPUs).
# --no-deps because the NGC PyTorch base already pins torch/triton/etc.
# PIP_CONSTRAINT= clears NGC's `packaging==23.2` pin during metadata parse.
RUN PIP_CONSTRAINT= pip install --no-build-isolation --no-deps -v -e .

# vLLM runtime deps that --no-deps skipped. NGC PyTorch already ships torch,
# numpy, scipy, etc.; vllm.entrypoints.cli imports a long transitive chain
# (fastapi, cbor2, pydantic, transformers, ...) that `python -c "import vllm"`
# happens not to trigger, so the smoke test passes while `vllm serve` and
# `vllm bench` crash on import. Install vllm's own requirements/common.txt
# wholesale to avoid whack-a-mole. Torch is pinned by NGC and common.txt
# doesn't pin torch, so no conflict.
# `python3-yaml` from apt installs PyYAML with no RECORD file, so pip can't
# upgrade it cleanly. Purge first so pip can manage it.
RUN apt-get update && apt-get remove -y --purge python3-yaml || true \
    && rm -rf /var/lib/apt/lists/*

# Pin torch/torchvision/triton to NGC's pre-release versions. Pip's transitive
# resolution of fastapi/transformers/etc. would otherwise pull PyPI torch 2.12.0
# stable, which has a different C++ ABI than NGC's 2.12.0a0+0291f960b6 — vllm's
# compiled `_C.abi3.so` is linked against the NGC ABI and an upgrade breaks it.
RUN echo "torch==$(python3 -c 'import torch; print(torch.__version__)')" >  /tmp/torch-pin.txt \
    && python3 -c "import torchvision; print(f'torchvision=={torchvision.__version__}')" >> /tmp/torch-pin.txt \
    && cat /tmp/torch-pin.txt

RUN PIP_CONSTRAINT=/tmp/torch-pin.txt pip install --upgrade \
        -r /opt/vllm-jasl/requirements/common.txt \
    && PIP_CONSTRAINT=/tmp/torch-pin.txt pip install --upgrade \
        ray[default] \
        opentelemetry-exporter-otlp

# jasl-specific quantization + spec-decode kernels. The vllm quantization
# registry imports `humming.dtypes.DataType` eagerly when ANY quantized model
# is loaded (not just humming-quantized ones), so the package must be
# importable even though Card B uses compressed-tensors NVFP4. `tokenspeed-mla`
# is needed for MTP spec decode. cu13 extras are skipped — they pull
# nvidia-cutlass-dsl 4.5.0 which wants CUDA 13 while NGC 26.04 ships CUDA 12.9
# (jasl's cuda.txt prefers cu13 but the cu12 path works at runtime).
RUN PIP_CONSTRAINT=/tmp/torch-pin.txt pip install --upgrade \
        humming-kernels \
        quack-kernels \
        tokenspeed-mla \
        fastsafetensors \
        flashinfer-python \
        flashinfer-cubin \
        tilelang

# DeepGEMM: jasl@27fd665b ships `sm12x_deep_gemm_fallbacks.py` as a self-contained
# Triton shim for SM 12.0, and `vllm.utils.deep_gemm` is a vLLM-internal module.
# The standalone `deep_gemm` package is not required on SM 12.0 — v3 script's
# `.deps/deepgemm-src` step was a no-op at this pin anyway.

# Runtime deps for serve + eval harnesses.
# `lm-eval>=0.4.12` for GSM8K/HumanEval/IFEval; `aiohttp` for the async AIME
# harness; `evalplus` for HumanEval+/MBPP+.
RUN PIP_CONSTRAINT= pip install --upgrade \
        huggingface_hub hf-transfer hf_xet \
        langdetect immutabledict nltk \
        "lm-eval>=0.4.12" evalplus openai datasets sentencepiece aiohttp

EXPOSE 8000

# Sanity check baked into the image: import vllm + verify CUDA visibility
# happens at `docker run`, not at build time (build host may have no GPU).
LABEL org.opencontainers.image.title="canada-quant/dsv4-rtx6000pro" \
      org.opencontainers.image.description="vLLM jasl/vllm@${VLLM_PIN} + 5 patches for DeepSeek-V4-Flash NVFP4/W4A16+MTP on RTX PRO 6000 Blackwell Server Edition (SM 12.0)" \
      org.opencontainers.image.source="https://github.com/canada-quant/dsv4-flash-nvfp4-fp8-mtp"

WORKDIR /workspace
